# Copy this file to .env.local and fill in your actual credentials.
# Never commit .env.local — it holds real secrets.

# Google Gemini — required (used for LLM calls and embeddings)
GOOGLE_API_KEY=AIza...

# Model names (defaults shown — override if needed)
GEMINI_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=models/gemini-embedding-2

# Local Chroma persistence path
CHROMA_PATH=data/chroma_db

# Observability (optional, but recommended for tracing and debugging)
LANGCHAIN_TRACING_V2: bool = True
LANGCHAIN_API_KEY: str = lv2_pt_...
LANGCHAIN_PROJECT: str = "bct_hack"